---
import LanguageSwitcher from '../LanguageSwitcher';
---

<header class="sticky top-0 z-40 w-full border-b border-gray-200 dark:border-white/10 bg-white/80 dark:bg-gray-900/80 backdrop-blur-md">
  <nav class="container mx-auto px-4 h-16 flex items-center justify-between" aria-label="Navegación principal">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 hover:opacity-80 transition-opacity group" aria-label="Ir a inicio">
      <img src="/Logo.svg" alt="Pixel Crunch Logo" class="w-8 h-8 transition-transform group-hover:scale-110" />
      <span class="text-xl font-bold text-gray-900 dark:text-monokai-fg">
        Pixel Crunch
      </span>
    </a>

    <!-- Navegación (desktop) -->
    <div class="hidden md:flex items-center gap-6">
      <a 
        href="/#features" 
        class="text-sm font-medium text-gray-700 dark:text-monokai-fg hover:text-brand-cyan dark:hover:text-brand-cyan-light transition-colors"
      >
        Características
      </a>
      <a 
        href="https://github.com/JosueMM01/pixel-crunch" 
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm font-medium text-gray-700 dark:text-monokai-fg hover:text-brand-cyan dark:hover:text-brand-cyan-light transition-colors"
        aria-label="Ver repositorio en GitHub (abre en nueva pestaña)"
      >
        GitHub
      </a>
    </div>

    <!-- Language Switcher -->
    <div class="ml-auto">
      <LanguageSwitcher client:load />
    </div>
  </nav>
</header>
