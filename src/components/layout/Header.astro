---
import LanguageSwitcher from '../LanguageSwitcher';
---

<header class="sticky top-0 z-40 w-full border-b border-gray-200 dark:border-gray-800 bg-white/80 dark:bg-gray-900/80 backdrop-blur-sm">
  <nav class="container mx-auto px-4 h-16 flex items-center justify-between" aria-label="Navegación principal">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 hover:opacity-80 transition-opacity" aria-label="Ir a inicio">
      <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path 
          d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4" 
          stroke="currentColor" 
          stroke-width="2" 
          stroke-linecap="round" 
          stroke-linejoin="round" 
          class="text-blue-600 dark:text-blue-400"
        />
        <polyline 
          points="7 10 12 15 17 10" 
          stroke="currentColor" 
          stroke-width="2" 
          stroke-linecap="round" 
          stroke-linejoin="round" 
          class="text-purple-600 dark:text-purple-400"
        />
        <line 
          x1="12" 
          y1="15" 
          x2="12" 
          y2="3" 
          stroke="currentColor" 
          stroke-width="2" 
          stroke-linecap="round" 
          stroke-linejoin="round" 
          class="text-pink-600 dark:text-pink-400"
        />
      </svg>
      <span class="text-xl font-bold text-gray-900 dark:text-gray-100">
        Pixel Crunch
      </span>
    </a>

    <!-- Navegación (desktop) -->
    <div class="hidden md:flex items-center gap-6">
      <a 
        href="/#features" 
        class="text-sm font-medium text-gray-600 dark:text-gray-300 hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
      >
        Características
      </a>
      <a 
        href="https://github.com/JosueMM01/pixel-crunch" 
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm font-medium text-gray-600 dark:text-gray-300 hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
        aria-label="Ver repositorio en GitHub (abre en nueva pestaña)"
      >
        GitHub
      </a>
    </div>

    <!-- Language Switcher -->
    <div class="ml-auto">
      <LanguageSwitcher client:load />
    </div>
  </nav>
</header>
