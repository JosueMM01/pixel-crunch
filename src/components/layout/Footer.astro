---
// Footer component - Identidad visual completa
---

<footer class="mt-16 border-t border-gray-200 dark:border-brand-blue/30 bg-gray-50 dark:bg-gray-800/50">
  <div class="container mx-auto px-8 md:px-12 py-10 max-w-7xl text-gray-700 dark:text-gray-300">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
      <!-- Columna 1: Logo, Descripción y Copyright -->
      <div class="text-center md:text-left">
        <!-- Logo y Nombre -->
        <a href="/" class="inline-flex items-center gap-2 group" aria-label="Ir a inicio">
          <img src="/Logo.svg" alt="Pixel Crunch Logo" class="h-8 w-8 rounded" />
          <span class="text-lg font-semibold group-hover:text-brand-blue transition-colors">
            Pixel Crunch
          </span>
        </a>
        
        <!-- Descripción -->
        <p class="mt-3 text-sm text-gray-600 dark:text-gray-400">
          Comprime y optimiza imágenes directamente en tu navegador. 100% privado, gratuito y open source.
        </p>
        
        <!-- Copyright -->
        <p class="mt-4 text-xs text-gray-500 dark:text-gray-500">
          © <span id="current-year"></span> Pixel Crunch. Todos los derechos reservados.
        </p>
      </div>

      <!-- Columna 2: Enlaces de Navegación -->
      <div class="md:mx-auto text-center md:text-left">
        <h3 class="text-sm font-semibold tracking-wide text-gray-900 dark:text-gray-200 uppercase">
          Navegación
        </h3>
        <div class="mx-auto md:mx-0 my-2 h-px w-10 bg-brand-blue/40"></div>
        <ul class="mt-4 space-y-2 text-sm flex flex-col items-center md:items-start">
          <li>
            <a 
              href="/#features" 
              class="hover:text-brand-blue"
            >
              Características
            </a>
          </li>
          <li>
            <a 
              href="https://github.com/JosueMM01/pixel-crunch" 
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-brand-blue inline-flex items-center gap-2"
            >
              <img src="/logos/github.svg" alt="GitHub" class="h-5 w-5 dark:invert" />
              <span>GitHub</span>
            </a>
          </li>
          <li>
            <a 
              href="https://github.com/JosueMM01/pixel-crunch/issues" 
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-brand-blue"
            >
              Reportar Bug
            </a>
          </li>
        </ul>
      </div>

      <!-- Columna 3: Stack Tecnológico -->
      <div class="md:justify-self-end text-center md:text-left">
        <h3 class="text-sm font-semibold tracking-wide text-gray-900 dark:text-gray-200 uppercase">
          Stack Tecnológico
        </h3>
        <div class="mx-auto md:mx-0 my-2 h-px w-10 bg-brand-blue/40"></div>
        <ul class="mt-4 space-y-2 text-sm flex flex-col items-center md:items-start">
          <li>
            <a 
              href="https://astro.build" 
              target="_blank" 
              rel="noopener noreferrer"
              class="hover:text-brand-blue inline-flex items-center gap-2"
            >
              <img src="/logos/astro.svg" alt="Astro" class="h-5 w-5" />
              <span>Astro 5</span>
            </a>
          </li>
          <li>
            <a 
              href="https://react.dev" 
              target="_blank" 
              rel="noopener noreferrer"
              class="hover:text-brand-blue inline-flex items-center gap-2"
            >
              <img src="/logos/react.svg" alt="React" class="h-5 w-5" />
              <span>React 19</span>
            </a>
          </li>
          <li>
            <a 
              href="https://tailwindcss.com" 
              target="_blank" 
              rel="noopener noreferrer"
              class="hover:text-brand-blue inline-flex items-center gap-2"
            >
              <img src="/logos/tailwind.svg" alt="Tailwind CSS" class="h-5 w-5" />
              <span>TailwindCSS v4</span>
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>
</footer>

<script>
  // Actualizar año automáticamente
  const yearElement = document.getElementById('current-year');
  if (yearElement) {
    yearElement.textContent = new Date().getFullYear().toString();
  }
</script>

