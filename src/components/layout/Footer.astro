---
// Footer component
---

<footer class="border-t border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900">
  <div class="container mx-auto px-4 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
      <!-- Logo y descripción -->
      <div class="space-y-4">
        <a href="/" class="flex items-center gap-3 hover:opacity-80 transition-opacity" aria-label="Ir a inicio">
          <img src="/Logo.svg" alt="Pixel Crunch Logo" class="w-8 h-8" />
          <span class="text-lg font-bold text-gray-900 dark:text-gray-100">
            Pixel Crunch
          </span>
        </a>
        <p class="text-sm text-gray-600 dark:text-gray-400">
          Comprime y optimiza imágenes directamente en tu navegador. 100% privado y gratuito.
        </p>
      </div>

      <!-- Enlaces -->
      <div class="space-y-4">
        <h3 class="text-sm font-semibold text-gray-900 dark:text-gray-100 uppercase tracking-wider">
          Enlaces
        </h3>
        <ul class="space-y-2">
          <li>
            <a 
              href="/#features" 
              class="text-sm text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
            >
              Características
            </a>
          </li>
          <li>
            <a 
              href="https://github.com/JosueMM01/pixel-crunch" 
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
            >
              GitHub
            </a>
          </li>
        </ul>
      </div>

      <!-- Tecnologías -->
      <div class="space-y-4">
        <h3 class="text-sm font-semibold text-gray-900 dark:text-gray-100 uppercase tracking-wider">
          Tecnologías
        </h3>
        <div class="flex flex-col gap-2 text-sm text-gray-600 dark:text-gray-400">
          <a 
            href="https://astro.build" 
            target="_blank" 
            rel="noopener noreferrer"
            class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
          >
            Astro 5
          </a>
          <a 
            href="https://react.dev" 
            target="_blank" 
            rel="noopener noreferrer"
            class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
          >
            React 19
          </a>
          <a 
            href="https://tailwindcss.com" 
            target="_blank" 
            rel="noopener noreferrer"
            class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
          >
            TailwindCSS v4
          </a>
        </div>
      </div>
    </div>

    <!-- Copyright -->
    <div class="pt-8 border-t border-gray-200 dark:border-gray-800">
      <p class="text-center text-sm text-gray-600 dark:text-gray-400">
        © <span id="current-year"></span> <span class="font-semibold text-gray-900 dark:text-gray-100">Pixel Crunch</span>. Todos los derechos reservados.
      </p>
    </div>
  </div>
</footer>

<script>
  // Actualizar año automáticamente
  document.getElementById('current-year')!.textContent = new Date().getFullYear().toString();
</script>
