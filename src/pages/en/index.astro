---
import Layout from '../../layouts/Layout.astro';
import { UploaderPanel } from '../../components/features/uploader';
import translations from '../../i18n/en.json';

const t = translations;
---

<Layout 
	title="Pixel Crunch - Optimize Images in Your Browser"
	description="Free and private tool to compress images (JPG, PNG, WebP) without uploading files to a server."
>
	<main class="min-h-screen bg-monokai-bg text-monokai-fg">
		<section class="px-4 pt-8 pb-8 md:pt-12 md:pb-10">
			<div id="home-hero-switcher" class="mx-auto w-full max-w-6xl">
				<div data-hero-panel="compressor" class="text-center">
					<h1 class="text-4xl md:text-5xl font-bold text-monokai-pink">Compress images online</h1>
					<p class="mt-5 text-lg md:text-2xl text-monokai-cyan max-w-4xl mx-auto">
						Compress and optimize images directly in your browser.
					</p>
					<p class="mt-5 text-base md:text-xl text-monokai-fg/85 max-w-5xl mx-auto">
						Compress and optimize JPG, PNG, and WebP images directly in your browser. No ads, no server uploads, and full quality control.
					</p>

					<ul class="mt-7 max-w-4xl mx-auto text-left text-base md:text-lg text-monokai-fg/90 space-y-2">
						<li class="flex gap-2"><span class="text-monokai-cyan">•</span><span>Drag and drop or select your images to get started.</span></li>
						<li class="flex gap-2"><span class="text-monokai-cyan">•</span><span>Compress, adjust quality, and review before/after results.</span></li>
					</ul>

					<div class="mt-6 flex flex-wrap items-center justify-center gap-2">
						{['JPG/JPEG/JFIF', 'PNG', 'WebP'].map((format) => (
							<span class="px-3 py-1.5 text-xs md:text-sm font-semibold rounded-md border border-monokai-cyan/30 text-monokai-cyan bg-monokai-bg/80">
								{format}
							</span>
						))}
					</div>
				</div>

				<div data-hero-panel="converter" class="hidden text-center">
					<h1 class="text-4xl md:text-5xl font-bold text-monokai-pink">Convert images online</h1>
					<p class="mt-5 text-base md:text-xl text-monokai-fg/85 max-w-5xl mx-auto">
						Free browser-based tool that converts HEIC, JPG, PNG, WebP, GIF, BMP, TIFF, AVIF, and ICO images to JPG, PNG, WebP, or AVIF. No server upload - conversion happens in your browser. Fast, secure, and private.
					</p>

					<ul class="mt-7 max-w-4xl mx-auto text-left text-base md:text-lg text-monokai-fg/90 space-y-2">
						<li class="flex gap-2"><span class="text-monokai-cyan">•</span><span>Drag and drop or select images - up to 20 files at once.</span></li>
						<li class="flex gap-2"><span class="text-monokai-cyan">•</span><span>Choose an output format, click CONVERT, then save each file.</span></li>
					</ul>
				</div>
			</div>
		</section>

		<section id="uploader" class="px-4 pb-12 md:pb-16">
			<div id="home-uploader-switcher" class="mx-auto w-full max-w-6xl rounded-2xl border border-monokai-fg/15 bg-monokai-bg/50 shadow-lg shadow-monokai-bg/40 overflow-hidden">
				<div class="flex items-center justify-start gap-2 px-4 py-3 border-b border-monokai-fg/10 bg-monokai-bg/70">
					<button
						type="button"
						data-upload-tab="converter"
						class="rounded-xl border border-monokai-fg/25 px-4 py-2 font-semibold text-monokai-fg/70"
						aria-selected="false"
					>
						Converter
					</button>
					<button
						type="button"
						data-upload-tab="compressor"
						class="rounded-xl border border-monokai-orange/40 bg-monokai-orange/10 px-4 py-2 font-semibold text-monokai-orange"
						aria-selected="true"
					>
						Compressor
					</button>
				</div>

				<div class="px-3 py-4 md:px-5 md:py-6">
					<div
						data-upload-panel="compressor"
						class="transition-[max-height,opacity,transform] duration-300 ease-out opacity-100 translate-y-0 max-h-[2200px]"
					>
						<UploaderPanel
							client:load
							uploadCopy={t.upload}
							qualityCopy={t.compression.quality}
							compressionProgressCopy={t.compression.progress}
							compressionStatsCopy={t.compression.stats}
							previewCopy={t.preview}
						/>
					</div>

					<div
						data-upload-panel="converter"
						class="pointer-events-none overflow-hidden transition-[max-height,opacity,transform] duration-300 ease-out opacity-0 -translate-y-2 max-h-0"
					>
						<div class="mx-auto w-full max-w-5xl rounded-2xl border border-monokai-fg/15 bg-monokai-bg/60 p-4 md:p-6">
							<div class="mb-3 flex flex-wrap justify-start gap-2">
								<button
									type="button"
									class="rounded-lg border border-monokai-cyan/35 px-3 py-1.5 text-sm font-semibold text-monokai-cyan hover:bg-monokai-cyan/10"
								>
									Add
								</button>
								<button
									type="button"
									class="rounded-lg border border-monokai-pink/35 px-3 py-1.5 text-sm font-semibold text-monokai-pink hover:bg-monokai-pink/10"
								>
									Clear
								</button>
							</div>

							<div class="rounded-xl border-2 border-dashed border-monokai-cyan/35 bg-monokai-bg/70 px-4 py-10 text-center">
								<p class="text-base md:text-lg font-semibold text-monokai-fg">Drag your images here to convert</p>
								<p class="mt-2 text-sm text-monokai-fg/65">Output available for JPG, PNG, WebP, and AVIF</p>
							</div>

							<div class="mt-4 grid grid-cols-2 gap-2 sm:grid-cols-4">
								{['JPG', 'PNG', 'WebP', 'AVIF'].map((format) => (
									<button
										type="button"
										class="rounded-lg border border-monokai-fg/25 bg-monokai-bg/70 px-3 py-2 text-sm font-semibold text-monokai-fg/80 hover:border-monokai-cyan/35 hover:text-monokai-cyan"
									>
										{format}
									</button>
								))}
							</div>

							<div class="mt-4 flex justify-center">
								<button
									type="button"
									class="rounded-lg border border-monokai-cyan/40 bg-monokai-cyan/10 px-4 py-2 text-sm font-semibold text-monokai-cyan"
								>
									Convert images
								</button>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section id="features" class="px-4 pb-16 md:pb-24">
			<div class="mx-auto w-full max-w-6xl space-y-8">
				<div id="home-docs-switcher" class="rounded-2xl border border-monokai-fg/15 bg-monokai-bg/55 p-5 md:p-7">
					<div data-doc-panel="compressor">
						<h2 class="text-2xl md:text-3xl font-bold text-monokai-pink">Compress images online</h2>
						<p class="mt-3 text-sm md:text-base text-monokai-fg/85">
							Compress and optimize images directly in your browser.
						</p>
						<p class="mt-3 text-sm md:text-base text-monokai-fg/85">
							Compress and optimize JPG, PNG, and WebP images directly in your browser. No ads, no server uploads, and full quality control.
						</p>
						<ul class="mt-4 space-y-2 text-sm md:text-base text-monokai-fg/90">
							<li class="flex gap-2"><span class="text-monokai-cyan">•</span><span>Drag and drop or select your images to get started.</span></li>
							<li class="flex gap-2"><span class="text-monokai-cyan">•</span><span>Compress, adjust quality, and review before/after results.</span></li>
						</ul>
					</div>

					<div class="hidden" data-doc-panel="converter">
						<h2 class="text-2xl md:text-3xl font-bold text-monokai-pink">Convert images online</h2>
						<p class="mt-3 text-sm md:text-base text-monokai-fg/85">
							Free browser-based tool that converts HEIC, JPG, PNG, WebP, GIF, BMP, TIFF, AVIF, and ICO images to JPG, PNG, WebP, or AVIF. No server upload - conversion happens in your browser. Fast, secure, and private.
						</p>
						<ul class="mt-4 space-y-2 text-sm md:text-base text-monokai-fg/90">
							<li class="flex gap-2"><span class="text-monokai-cyan">•</span><span>Drag and drop or select images - up to 20 files at once.</span></li>
							<li class="flex gap-2"><span class="text-monokai-cyan">•</span><span>Choose an output format, click CONVERT, then save each file.</span></li>
						</ul>
					</div>
				</div>

				<div class="grid md:grid-cols-3 gap-5">
					<div class="rounded-xl border border-monokai-pink/35 bg-monokai-bg/60 p-5">
						<h3 class="text-lg font-bold text-monokai-pink">{t.benefits.privacy.title}</h3>
						<p class="mt-2 text-sm text-monokai-fg/75">{t.benefits.privacy.description}</p>
					</div>
					<div class="rounded-xl border border-monokai-yellow/35 bg-monokai-bg/60 p-5">
						<h3 class="text-lg font-bold text-monokai-yellow">{t.benefits.fast.title}</h3>
						<p class="mt-2 text-sm text-monokai-fg/75">{t.benefits.fast.description}</p>
					</div>
					<div class="rounded-xl border border-monokai-green/35 bg-monokai-bg/60 p-5">
						<h3 class="text-lg font-bold text-monokai-green">{t.benefits.free.title}</h3>
						<p class="mt-2 text-sm text-monokai-fg/75">{t.benefits.free.description}</p>
					</div>
				</div>
			</div>
		</section>
	</main>

	<script is:inline>
		(() => {
			const uploaderRoot = document.getElementById('home-uploader-switcher');
			const heroRoot = document.getElementById('home-hero-switcher');
			const docsRoot = document.getElementById('home-docs-switcher');

			if (uploaderRoot) {
				const uploadTabBase = ['rounded-xl', 'border', 'px-4', 'py-2', 'font-semibold'];
				const uploadTabActive = ['border-monokai-orange/40', 'bg-monokai-orange/10', 'text-monokai-orange'];
				const uploadTabInactive = ['border-monokai-fg/25', 'text-monokai-fg/70'];

				const uploadTabs = Array.from(uploaderRoot.querySelectorAll('[data-upload-tab]'));
				const uploadPanels = Array.from(uploaderRoot.querySelectorAll('[data-upload-panel]'));
				const heroPanels = heroRoot
					? Array.from(heroRoot.querySelectorAll('[data-hero-panel]'))
					: [];
				const docPanels = docsRoot
					? Array.from(docsRoot.querySelectorAll('[data-doc-panel]'))
					: [];

				const setUploadMode = (mode) => {
					uploadTabs.forEach((tab) => {
						const isActive = tab.getAttribute('data-upload-tab') === mode;
						tab.className = [...uploadTabBase, ...(isActive ? uploadTabActive : uploadTabInactive)].join(' ');
						tab.setAttribute('aria-selected', isActive ? 'true' : 'false');
					});

					uploadPanels.forEach((panel) => {
						const isActive = panel.getAttribute('data-upload-panel') === mode;
						panel.classList.toggle('pointer-events-none', !isActive);
						panel.classList.toggle('overflow-hidden', !isActive);
						panel.classList.toggle('opacity-0', !isActive);
						panel.classList.toggle('-translate-y-2', !isActive);
						panel.classList.toggle('max-h-0', !isActive);
						panel.classList.toggle('opacity-100', isActive);
						panel.classList.toggle('translate-y-0', isActive);
						panel.classList.toggle('max-h-[2200px]', isActive);
					});

					heroPanels.forEach((panel) => {
						const isActive = panel.getAttribute('data-hero-panel') === mode;
						panel.classList.toggle('hidden', !isActive);
					});

					docPanels.forEach((panel) => {
						const isActive = panel.getAttribute('data-doc-panel') === mode;
						panel.classList.toggle('hidden', !isActive);
					});
				};

				uploadTabs.forEach((tab) => {
					tab.addEventListener('click', () => {
						const mode = tab.getAttribute('data-upload-tab') || 'compressor';
						setUploadMode(mode);
					});
				});

				setUploadMode('compressor');
			}
		})();
	</script>
</Layout>
